# Neon: pooled connection (для приложения на Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon: direct connection (для prisma migrate / db push)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# view-db: локальная и рабочая БД (если не заданы — используется DATABASE_URL)
DATABASE_URL_LOCAL="postgresql://USER:PASSWORD@localhost:5432/businesscase"
DATABASE_URL_WORK="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# view-db: порт (по умолчанию 3847)
VIEW_DB_PORT=3847